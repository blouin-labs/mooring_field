# GitHub Actions org runner registration token.
# Generate at: https://github.com/organizations/blouin-labs/settings/actions/runners/new
# One-time use — the runner deregisters and re-registers on each container restart.
# If the token expires after a restart, generate a new one and update this file.
ACTIONS_RUNNER_INPUT_TOKEN=

# SSH private key for gh-deploy@harbor-srv, base64-encoded (no newlines).
# Generate: base64 -w0 < /path/to/gh_deploy_key
# The corresponding public key must be in harbor-srv's /var/lib/gh-deploy/.ssh/authorized_keys.
GH_DEPLOY_SSH_KEY_B64=

